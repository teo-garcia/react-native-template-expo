{
  "name": "react-native-template-expo",
  "version": "0.0.0",
  "private": true,
  "author": "teo-garcia",
  "packageManager": "pnpm@10.2.0",
  "engines": {
    "node": ">=24"
  },
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "dev:web": "expo start --web",
    "build": "expo export --platform web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "start": "npx serve dist",
    "lint:es": "eslint . --fix",
    "lint:es:check": "eslint .",
    "lint:ts": "tsc --noEmit",
    "lint:format": "pnpm format",
    "lint:format:check": "pnpm format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "check": "pnpm lint:es:check && pnpm lint:ts && pnpm format:check && pnpm test",
    "docker:dev": "docker compose up --build"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/elements": "^2.0.0",
    "@tanstack/react-query": "^5.90.11",
    "expo": "~55.0.0",
    "expo-blur": "~55.0.0",
    "expo-constants": "~55.0.0",
    "expo-font": "~55.0.0",
    "expo-haptics": "~55.0.0",
    "expo-image": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-router": "~55.0.0",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "expo-system-ui": "~55.0.0",
    "expo-web-browser": "~55.0.0",
    "lucide-react-native": "^0.577.0",
    "nativewind": "preview",
    "react": "19.2.4",
    "react-native": "0.83.2",
    "react-native-css": "*",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^10.0.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@teo-garcia/eslint-config-shared": "^0.4.0",
    "@teo-garcia/prettier-config-shared": "^0.2.8",
    "@teo-garcia/tsconfig-shared": "^0.2.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^61.0.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.0",
    "prettier": "^3.7.3",
    "react-test-renderer": "19.2.4",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3"
  },
  "prettier": "@teo-garcia/prettier-config-shared",
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|react-native-svg|nativewind))",
      "/node_modules/react-native-reanimated/plugin/"
    ],
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "components/**/*.{ts,tsx}",
      "features/**/*.{ts,tsx}",
      "lib/**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!**/__mocks__/**"
    ]
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  }
}
