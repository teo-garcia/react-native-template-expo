{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackagePatterns": ["@teo-garcia/*"],
      "automerge": false
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackagePatterns": ["*"],
      "automerge": true
    },
    {
      "matchPackagePatterns": ["expo", "expo-*", "react-native"],
      "automerge": false
    }
  ]
}
